# LLM provider: "anthropic", "openai", or "fireworks"
CHRONICLE_LLM_PROVIDER=anthropic
CHRONICLE_LLM_MODEL=claude-haiku-4-5-20251001

# For Fireworks Kimi K2:
#   CHRONICLE_LLM_PROVIDER=fireworks
#   CHRONICLE_LLM_MODEL=accounts/fireworks/models/kimi-k2p6

# API keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FIREWORKS_API_KEY=

# Memory builder poll interval (ms)
CHRONICLE_MEMORY_INTERVAL_MS=30000
