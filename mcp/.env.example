# LLM provider: anthropic | openai | fireworks | ollama | lmstudio | openaiCompatible
CHRONICLE_LLM_PROVIDER=anthropic
CHRONICLE_LLM_MODEL=claude-haiku-4-5-20251001

# Presets:
#
# Fireworks Kimi K2:
#   CHRONICLE_LLM_PROVIDER=fireworks
#   CHRONICLE_LLM_MODEL=accounts/fireworks/models/kimi-k2p6
#
# Local Ollama (run `ollama pull <model>` first):
#   CHRONICLE_LLM_PROVIDER=ollama
#   CHRONICLE_LLM_MODEL=llama3.2
#   CHRONICLE_OLLAMA_URL=http://localhost:11434/v1     (optional, default)
#
# LM Studio (start the local server in LM Studio first):
#   CHRONICLE_LLM_PROVIDER=lmstudio
#   CHRONICLE_LLM_MODEL=qwen2.5-7b-instruct
#   CHRONICLE_LMSTUDIO_URL=http://localhost:1234/v1    (optional, default)
#
# Any OpenAI-compatible endpoint (Baseten, Groq, Together, vLLM, TGI, etc.):
#   CHRONICLE_LLM_PROVIDER=openaiCompatible
#   CHRONICLE_LLM_MODEL=<whatever the endpoint expects>
#   CHRONICLE_OPENAI_COMPAT_URL=https://api.example.com/v1
#   CHRONICLE_OPENAI_COMPAT_API_KEY=<if required>

# Credentials (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FIREWORKS_API_KEY=
CHRONICLE_OLLAMA_URL=
CHRONICLE_LMSTUDIO_URL=
CHRONICLE_OPENAI_COMPAT_URL=
CHRONICLE_OPENAI_COMPAT_API_KEY=

# Memory builder poll interval (ms)
CHRONICLE_MEMORY_INTERVAL_MS=30000
